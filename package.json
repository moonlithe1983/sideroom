{
  "name": "sideroom",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "typecheck": "tsc --noEmit",
    "backend:preflight": "node ./scripts/supabase-preflight.js",
    "release:preflight": "node ./scripts/release-preflight.js",
    "backend:bundle": "node ./scripts/build-supabase-bundle.js",
    "handoff:docx": "PowerShell -ExecutionPolicy Bypass -File ./scripts/build-handoff-docx.ps1",
    "launch:seed": "node ./scripts/build-launch-seed.js",
    "android": "expo start --android",
    "doctor": "expo-doctor",
    "audit:check": "npm audit --audit-level=high",
    "build:preview:android": "npx eas-cli build --platform android --profile preview",
    "build:production:android": "npx eas-cli build --platform android --profile production",
    "submit:production:android": "npx eas-cli submit --platform android --profile production",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.99.3",
    "aes-js": "^3.1.2",
    "expo": "~55.0.15",
    "expo-constants": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.8",
    "expo-linking": "~55.0.13",
    "expo-local-authentication": "~55.0.13",
    "expo-router": "~55.0.12",
    "expo-screen-capture": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "expo-doctor": "^1.18.13",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "brace-expansion": "^5.0.5",
    "flatted": "^3.4.2",
    "minimatch": "^10.2.4"
  },
  "private": true
}
